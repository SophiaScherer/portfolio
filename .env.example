# SMTP credentials for the contact form. Copy to `.env.local` and fill in.
# Without these, the contact form will return a 500 error if submitted.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Email address that receives contact form submissions.
# Recommended: set this explicitly. If unset, the API will send to SMTP_USER.
CONTACT_TO=your-email@example.com
